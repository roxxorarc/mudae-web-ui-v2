# === COMMON & DATABASE ===
# Connection pooler URL (for SQLAlchemy / FastAPI / Bot)
DATABASE_URL="postgresql+asyncpg://user:password@host:6543/postgres?pgbouncer=true"
# Direct connection URL (for Alembic migrations)
DIRECT_URL="postgresql+asyncpg://user:password@host:5432/postgres"

# === SUPABASE ===
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your_supabase_anon_key"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"

# === DISCORD BOT ===
APPLICATION_ID="your_discord_application_id"
DISCORD_CLIENT_ID="your_discord_client_id"
DISCORD_TOKEN="your_discord_bot_token"
CHANNEL_IDS="123456789,987654321"

# === FRONTEND (Vite Prefix) ===
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your_supabase_anon_key"
VITE_ENABLE_API_LOGS=false
